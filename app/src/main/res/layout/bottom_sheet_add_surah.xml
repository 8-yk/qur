<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:background="@color/bg_surface">

    <!-- مقبض -->
    <View android:layout_width="40dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal" android:layout_marginTop="10dp"
        android:background="@color/text_secondary" android:alpha="0.4"/>

    <!-- عنوان -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="20dp" android:paddingTop="12dp" android:paddingBottom="6dp">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="إضافة سورة جديدة"
            android:textColor="@color/gold_primary"
            android:textSize="18sp"
            android:fontFamily="serif"
            android:textStyle="bold"/>

        <ImageButton android:id="@+id/btnAddSurahClose"
            android:layout_width="36dp" android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/text_secondary"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider_color" android:layout_marginBottom="16dp"/>

    <!-- رقم السورة -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="@color/gold_dim"
        android:hint="رقم السورة">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSurahNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="@color/text_primary"
            android:gravity="end"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- اسم السورة -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="@color/gold_dim"
        android:hint="اسم السورة">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSurahName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:fontFamily="serif"
            android:gravity="end"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Chips مكية / مدنية -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupAddMeccan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        android:layoutDirection="rtl">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAddMeccan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="مكية"
            android:checked="true"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_bg_selector"
            android:textColor="@color/text_primary"
            app:checkedIconTint="@color/gold_primary"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAddMadani"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="مدنية"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_bg_selector"
            android:textColor="@color/text_primary"
            app:checkedIconTint="@color/gold_primary"/>
    </com.google.android.material.chip.ChipGroup>

    <!-- ملاحظة -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="12dp"
        android:text="عدد الآيات يُحسب تلقائياً من الآيات التي ستضيفها"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:gravity="center"/>

    <!-- زر الإضافة -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmAddSurah"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="28dp"
        android:text="إضافة السورة"
        android:enabled="false"
        app:cornerRadius="14dp"
        app:backgroundTint="@color/gold_primary"
        android:textColor="@color/bg_primary"
        android:textSize="15sp"/>

</LinearLayout>
