<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:background="@color/bg_surface">

    <View android:layout_width="40dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal" android:layout_marginTop="10dp"
        android:background="@color/text_secondary" android:alpha="0.4"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="20dp" android:paddingTop="10dp" android:paddingBottom="6dp">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="إضافة سورة جديدة"
            android:textColor="@color/gold_primary" android:textSize="18sp"
            android:fontFamily="serif" android:textStyle="bold"/>

        <ImageButton android:id="@+id/btnAddSurahClose" android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/text_secondary"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider_color" android:layout_marginBottom="8dp"/>

    <!-- حقل البحث -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp" android:layout_marginBottom="6dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
        app:boxCornerRadiusTopStart="20dp" app:boxCornerRadiusTopEnd="20dp"
        app:boxCornerRadiusBottomStart="20dp" app:boxCornerRadiusBottomEnd="20dp"
        app:boxStrokeColor="@color/gold_dim"
        app:startIconDrawable="@android:drawable/ic_menu_search"
        app:startIconTint="@color/text_secondary"
        android:hint="ابحث عن سورة...">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etAddSurahSearch"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:gravity="end"
            android:inputType="text" android:imeOptions="actionSearch"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- قائمة السور -->
    <ListView android:id="@+id/listAddSurah"
        android:layout_width="match_parent" android:layout_height="220dp"
        android:divider="@color/divider_color" android:dividerHeight="1dp"/>

    <!-- السورة المختارة -->
    <TextView android:id="@+id/tvAddSurahSelected"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center" android:textColor="@color/gold_primary"
        android:textSize="15sp" android:fontFamily="serif" android:textStyle="bold"
        android:paddingVertical="8dp" android:paddingHorizontal="20dp"
        android:visibility="gone"/>

    <!-- Chips مكية/مدنية -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupAddMeccan"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp" android:layout_marginBottom="6dp"
        app:singleSelection="true" app:selectionRequired="true"
        android:layoutDirection="rtl">

        <com.google.android.material.chip.Chip android:id="@+id/chipAddMeccan"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="مكية" android:checked="true"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_bg_selector"
            android:textColor="@color/text_primary"
            app:checkedIconTint="@color/gold_primary"/>

        <com.google.android.material.chip.Chip android:id="@+id/chipAddMadani"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="مدنية"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_bg_selector"
            android:textColor="@color/text_primary"
            app:checkedIconTint="@color/gold_primary"/>
    </com.google.android.material.chip.ChipGroup>

    <!-- عدد الآيات -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp" android:layout_marginBottom="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
        app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="@color/gold_dim"
        android:hint="عدد آيات السورة (يُملأ تلقائياً)">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etAddAyahsCount"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="number" android:textColor="@color/text_primary"
            android:gravity="end"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmAddSurah"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp" android:layout_marginBottom="24dp"
        android:text="إضافة السورة" app:cornerRadius="14dp"
        app:backgroundTint="@color/gold_primary" android:textColor="@color/bg_primary"
        android:textSize="15sp"/>

</LinearLayout>
