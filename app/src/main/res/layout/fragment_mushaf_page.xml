<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- إطار الصفحة الخارجي -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:margin="10dp"
        android:padding="2dp"
        android:background="@drawable/bg_mushaf_page_border">

        <!-- رأس السورة -->
        <TextView
            android:id="@+id/tvMushafSurahHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/gold_primary"
            android:textSize="18sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:paddingVertical="12dp"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_surah_header_band" />

        <!-- البسملة -->
        <TextView
            android:id="@+id/tvBismillah"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"
            android:gravity="center"
            android:textColor="@color/gold_primary"
            android:textSize="19sp"
            android:fontFamily="serif"
            android:paddingTop="14dp"
            android:paddingBottom="8dp"
            android:visibility="gone" />

        <!-- محتوى الآيات -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fadeScrollbars="true">

            <TextView
                android:id="@+id/tvMushafContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:fontFamily="serif"
                android:lineSpacingMultiplier="2.0"
                android:paddingHorizontal="18dp"
                android:paddingVertical="14dp"
                android:textAlignment="center"
                android:visibility="gone" />

        </ScrollView>

        <!-- الحالة الفارغة -->
        <LinearLayout
            android:id="@+id/tvMushafEmpty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="﴿  ﴾"
                android:textSize="40sp"
                android:textColor="@color/gold_dim"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="لم يُضَف نص لهذه السورة بعد"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="12dp"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="اذهب إلى قسم الإضافة لبناء بياناتك"
                android:textColor="@color/gold_dim"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

    <!-- مؤشر التحميل -->
    <ProgressBar
        android:id="@+id/mushafProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</FrameLayout>
