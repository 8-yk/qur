<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- صفحة المصحف -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_margin="8dp"
        android:background="@drawable/bg_mushaf_page_border">

        <!-- رأس السورة المزخرف -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_surah_header_band">

            <TextView
                android:id="@+id/tvMushafSurahHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/gold_primary"
                android:textSize="18sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:paddingVertical="14dp"
                android:paddingHorizontal="16dp" />
        </FrameLayout>

        <!-- خط زخرفي فاصل -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gold_dim"
            android:alpha="0.5" />

        <!-- البسملة -->
        <TextView
            android:id="@+id/tvBismillah"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"
            android:gravity="center"
            android:textColor="@color/gold_primary"
            android:textSize="20sp"
            android:fontFamily="serif"
            android:paddingTop="16dp"
            android:paddingBottom="4dp"
            android:visibility="gone" />

        <!-- خط تحت البسملة -->
        <View
            android:id="@+id/bismillahDivider"
            android:layout_width="120dp"
            android:layout_height="1dp"
            android:layout_gravity="center_horizontal"
            android:background="@color/gold_dim"
            android:alpha="0.4"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- نص الآيات -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbarThumbVertical="@color/gold_dim"
            android:fadingEdgeLength="16dp"
            android:requiresFadingEdge="vertical">

            <TextView
                android:id="@+id/tvMushafContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:lineSpacingMultiplier="2.2"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="20dp"
                android:textAlignment="center"
                android:visibility="gone" />
        </ScrollView>

        <!-- حالة فارغة -->
        <TextView
            android:id="@+id/tvMushafEmpty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="﴿ لم يُضَف نص لهذه السورة ﴾\n\nاذهب إلى تبويب الإضافة لبناء بياناتك"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.8"
            android:visibility="gone" />

        <!-- خط سفلي زخرفي -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gold_dim"
            android:alpha="0.3" />

    </LinearLayout>

    <!-- مؤشر التحميل -->
    <ProgressBar
        android:id="@+id/mushafProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</FrameLayout>
