<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- صفحات المصحف -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="92dp"
        android:paddingBottom="70dp"
        android:clipToPadding="false" />

    <!-- شريط علوي -->
    <LinearLayout
        android:id="@+id/mushafTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_surface"
        android:elevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layoutDirection="rtl"
            android:gravity="center_vertical"
            android:paddingTop="52dp"
            android:paddingBottom="8dp"
            android:paddingHorizontal="16dp">

            <!-- اسم السورة -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvMushafSurahName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gold_primary"
                    android:textSize="17sp"
                    android:fontFamily="serif"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvMushafSurahMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginTop="1dp" />
            </LinearLayout>

            <!-- زر الانتقال -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMushafJump"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="انتقل ›"
                android:textSize="13sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/gold_dim"
                android:textColor="@color/gold_primary"
                app:cornerRadius="18dp"
                android:paddingHorizontal="14dp" />
        </LinearLayout>

        <!-- شريط تقدم رفيع -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/mushafTopProgress"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            app:trackCornerRadius="0dp"
            app:indicatorColor="@color/gold_primary"
            app:trackColor="@color/gold_track"
            android:progress="0" />

    </LinearLayout>

    <!-- شريط سفلي: السابق / رقم السورة / التالي -->
    <LinearLayout
        android:id="@+id/mushafBottomBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:layoutDirection="rtl"
        android:gravity="center_vertical"
        android:background="@color/bg_surface"
        android:elevation="6dp"
        android:paddingHorizontal="8dp">

        <!-- السابق -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMushafPrev"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹ السابقة"
            android:textSize="13sp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@color/gold_primary" />

        <!-- رقم / من -->
        <TextView
            android:id="@+id/tvMushafPageNum"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- التالي -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMushafNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="التالية ›"
            android:textSize="13sp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@color/gold_primary" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
