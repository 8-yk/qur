<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layoutDirection="rtl">

        <!-- نص الآية -->
        <TextView
            android:id="@+id/tvAyahText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:lineSpacingMultiplier="1.85"
            android:gravity="end"
            android:paddingHorizontal="18dp"
            android:paddingTop="16dp"
            android:paddingBottom="10dp"
            android:textAlignment="textEnd" />

        <!-- شريط سفلي: رقم الآية + معلومات -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/ayah_footer_bg"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp">

            <!-- رقم الآية -->
            <TextView
                android:id="@+id/tvAyahNumber"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:textColor="@color/gold_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_ayah_number" />

            <!-- معلومات جزء/صفحة -->
            <TextView
                android:id="@+id/tvAyahMeta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:gravity="end"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
