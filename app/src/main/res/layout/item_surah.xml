<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardSurah"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="14dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:layoutDirection="rtl">

        <!-- رقم الآية في دائرة -->
        <TextView
            android:id="@+id/tvSurahNumber"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:textColor="@color/gold_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_number_circle" />

        <!-- نقطة خضراء للسور الموجودة -->
        <View
            android:id="@+id/viewDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_dot_green"
            android:visibility="invisible" />

        <!-- اسم السورة -->
        <TextView
            android:id="@+id/tvSurahName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/tvSurahNumber"
            android:layout_toEndOf="@id/viewDot"
            android:layout_marginEnd="12dp"
            android:layout_marginStart="12dp"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:fontFamily="serif"
            android:textStyle="bold" />

        <!-- مكية/مدنية + عدد الآيات -->
        <TextView
            android:id="@+id/tvSurahMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvSurahName"
            android:layout_toStartOf="@id/tvSurahNumber"
            android:layout_toEndOf="@id/viewDot"
            android:layout_marginEnd="12dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="3dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <!-- شارة "محفوظة" -->
        <TextView
            android:id="@+id/tvBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:text="محفوظة"
            android:textColor="@color/green_accent"
            android:textSize="10sp"
            android:background="@drawable/bg_badge_green"
            android:paddingHorizontal="7dp"
            android:paddingVertical="2dp"
            android:visibility="gone" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>
