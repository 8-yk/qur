<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- الخلفية الداكنة -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#141720" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <!-- إطار ذهبي رفيع -->
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#7A6530" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <!-- إطار داخلي أرق -->
    <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <stroke android:width="0.5dp" android:color="#3A3010" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>
